# Statics – copy to .env.local and fill in. No secrets are hardcoded; all from env.
# For Netlify: set the same variables in Site configuration → Environment variables. See NETLIFY-ENV.md.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cognito (required for sign-in/sign-up in production)
NEXT_PUBLIC_COGNITO_REGION=us-east-1
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=

# AWS (required for Cognito + DynamoDB + S3). IAM user must be in same account as Cognito pool.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# DynamoDB tables
STATICS_USERS_TABLE=statics_users
STATICS_APPS_TABLE=statics_apps
STATICS_SUBSCRIPTIONS_TABLE=statics_subscriptions
STATICS_SUBSCRIPTION_STOP_TABLE=statics_subscription_stop
STATICS_VERIFY_TABLE=statics_verify

# S3 avatar upload
AWS_S3_AVATAR_BUCKET=statics-avatars-YOUR_ACCOUNT_ID
NEXT_PUBLIC_AVATAR_BASE_URL=https://statics-avatars-YOUR_ACCOUNT_ID.s3.us-east-1.amazonaws.com

# Twilio (optional; for SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_VERIFY_SERVICE_ID=

# Optional
STATICS_ADMIN_EMAIL=
STATICS_MARCH_MADNESS_API_KEY=
NEXT_PUBLIC_FB_APP_ID=
