# Statics – copy to .env.local and fill in. All integrations are real when set.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cognito (required for production; when unset, in-memory mock auth is used for local dev)
# App client must allow USER_PASSWORD_AUTH for server-side sign-in.
NEXT_PUBLIC_COGNITO_REGION=us-east-1
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=

# Twilio (required for SMS; when unset, sendSms returns "not configured")
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Optional: Twilio Verify service ID for 2FA (same flow as Twilly). When set, codes are sent/verified via Verify API instead of SMS body.
TWILIO_VERIFY_SERVICE_ID=

# AWS + DynamoDB (required for production; when unset, in-memory mock data is used)
# On Netlify, also set AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY in the site env (not here).
AWS_REGION=us-east-1
STATICS_USERS_TABLE=
STATICS_APPS_TABLE=
STATICS_SUBSCRIPTIONS_TABLE=
STATICS_SUBSCRIPTION_STOP_TABLE=
# Optional: phone 2FA verification codes (recommended when running multiple app instances so codes persist)
STATICS_VERIFY_TABLE=

# S3 avatar upload (optional; profile picture lives in S3)
AWS_S3_AVATAR_BUCKET=
NEXT_PUBLIC_AVATAR_BASE_URL=

# March Madness backend: API key for GET /api/products/march-madness/allowed-numbers
STATICS_MARCH_MADNESS_API_KEY=
