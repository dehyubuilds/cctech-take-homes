AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Dynamo jobs table — SAM stack output **JobsTableName** (must match Statics config.youtubeImport.localWsJobsTable)
JOBS_TABLE=local-youtube-import-ws-JobsTable-171HZRV7TTC6M

# SAM output **ManagementApiEndpoint** (https … /prod — not wss)
AWS_APIGW_WS_MANAGEMENT_ENDPOINT=https://n87m5zq2n5.execute-api.us-east-1.amazonaws.com/prod

# Same bucket / prefixes as Dropflow
S3_BUCKET=statics-dropflow-142770202579

# Optional: Netscape cookies for yt-dlp on your residential IP
# YOUTUBE_COOKIES_FILE=/path/to/cookies.txt

# Art of the Question (jobKind=aotq_whisper): bridge forwards to local FastAPI worker
# AOTQ_LOCAL_WORKER_INTERNAL_URL=http://127.0.0.1:8787
# Bearer: run_worker.py also auto-merges scripts/aotq-ec2-worker/.env (AOTQ_WORKER_BEARER_TOKEN).
# Override here only if needed:
# AOTQ_WORKER_BEARER_TOKEN=
# AOTQ_WORKER_API_SECRET=
# AOTQ_LOCAL_WORKER_INTERNAL_BEARER=
# Optional: AOTQ_LOCAL_WS_POLL_TIMEOUT_SEC=2700
