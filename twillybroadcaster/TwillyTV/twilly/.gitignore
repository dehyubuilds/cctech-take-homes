.DS_Store
node_modules
/dist
.output


# local env files
.env
.env.local
.env.*.local

# Nuxt build cache
.nuxt

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor directories and files
.idea
.vscode
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

#amplify-do-not-edit-begin
amplify/\#current-cloud-backend
amplify/.config/local-*
amplify/logs
amplify/mock-data
amplify/mock-api-resources
amplify/backend/amplify-meta.json
amplify/backend/.temp
build/
dist/
node_modules/
aws-exports.js
awsconfiguration.json
amplifyconfiguration.json
amplifyconfiguration.dart
amplify-build-config.json
amplify-gradle-config.json
amplifytools.xcconfig
.secret-*
**.sample
#amplify-do-not-edit-end

# Large binary files and build artifacts
*.zip
*.tar.xz
*.tar.gz
*.tar.bz2

# FFmpeg and media processing files
lambda-layer/
ffmpeg
ffprobe

# Nginx source files
nginx-*/
nginx-rtmp-module-*/

# Test and temporary files
test*.json
test*.txt
test*.m3u8
response*.json
real-test-event.json

# Lambda build artifacts
lambda-package/
lambda/*.zip

# Large image files (if they're not needed)
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tiff
*.webp
# Allow public app assets (required for build, e.g. checkout page)
!public/images/
!public/images/*.png
!public/images/*.jpg
!public/images/*.jpeg
!public/images/*.gif
!public/images/*.webp
# Allow assets imported by Vue (required for build)
!assets/
!assets/*.png
!assets/*.jpg
!assets/*.jpeg
!assets/*.gif
!assets/*.webp
!assets/*.svg

# Executable files
*.exe
*.dll
*.so
*.dylib
*.bin

# Archive files
*.7z
*.rar
*.tar

# Temporary files
*.tmp
*.temp
*.log
*.bak
*.backup
